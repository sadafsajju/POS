{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the POS desktop app",
  "windows": ["main", "customer-display", "token-display"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-webview-close",
    "core:webview:allow-set-webview-focus",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "sql:default",
    "store:default",
    "shell:default",
    "updater:default",
    "process:default"
  ]
}
