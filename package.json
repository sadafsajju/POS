{
  "name": "pos-system",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:desktop": "turbo run dev --filter=@pos/desktop",
    "dev:customer": "turbo run dev --filter=@pos/customer-web",
    "dev:web": "turbo run dev --filter=@pos/web",
    "build": "turbo run build",
    "build:desktop": "turbo run build --filter=@pos/desktop",
    "build:customer": "turbo run build --filter=@pos/customer-web",
    "build:mac": "cd apps/desktop && npm run tauri build -- --target universal-apple-darwin",
    "build:win": "cd apps/desktop && npm run tauri build -- --target x86_64-pc-windows-msvc",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:up": "docker-compose up -d postgres",
    "db:down": "docker-compose down",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:migrate": "npx supabase db push",
    "supabase:gen-types": "npx supabase gen types typescript --local > packages/supabase/src/types.ts"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@10.2.0"
}
